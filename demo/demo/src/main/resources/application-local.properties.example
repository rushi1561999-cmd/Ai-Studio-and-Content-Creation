# Copy to application-local.properties (loaded automatically via spring.config.import)

# Gemini (text + rich content)
ai.gemini.api.key=your_gemini_api_key_here

# Replicate (image + video) — https://replicate.com/account/api-tokens
replicate.api.token=your_replicate_token_here

# Use Pollinations when Replicate token is empty (images only)
ai.image.fallback.enabled=true

# Stripe TEST keys — https://dashboard.stripe.com/test/apikeys
stripe.api.key=sk_test_your_secret_key
stripe.webhook.secret=whsec_your_webhook_secret

# Local dev webhook (run in a separate terminal):
#   stripe listen --forward-to localhost:8081/api/stripe/webhook
# Copy the whsec_... secret from that command into stripe.webhook.secret above.

app.frontend.url=http://localhost:5173
