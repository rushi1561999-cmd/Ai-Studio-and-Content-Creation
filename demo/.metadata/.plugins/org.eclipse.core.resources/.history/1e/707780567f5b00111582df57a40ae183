package com.example.demo.queue;

import com.example.demo.config.RabbitMQConfig;
import com.example.demo.service.ai.GeminiService; // Your new import
import com.example.demo.dto.AiJobMessage;
import com.example.demo.entity.GenerationJob;
import com.example.demo.repository.GenerationJobRepository;
import org.springframework.amqp.rabbit.annotation.RabbitListener;
import org.springframework.stereotype.Service;

@Service
public class AiJobConsumer {

    // 1. Declare the new Gemini Service
    private final GeminiService geminiService; 
    private final GenerationJobRepository jobRepository;

    // 2. Inject it via the Constructor
    public AiJobConsumer(GeminiService geminiService, GenerationJobRepository jobRepository) {
        this.geminiService = geminiService;
        this.jobRepository = jobRepository;
    }

    @RabbitListener(queues = RabbitMQConfig.QUEUE)
    public void processAiJob(AiJobMessage message) {
        // 1. Find the job and mark as PROCESSING
        GenerationJob job = jobRepository.findById(message.getJobId()).orElse(null);
        if (job == null) return;
        
        job.setStatus("PROCESSING");
        jobRepository.save(job);

        try {
            // 2. Call Google Gemini! (Using the generateText method we created)
            String aiResponse = geminiService.generateText(message.getPromptText());

            // 3. Save the result and mark as COMPLETED
            job.setResult(aiResponse);
            job.setStatus("COMPLETED");
            jobRepository.save(job);
            
            System.out.println("✅ Background Job Completed with REAL AI for ID: " + job.getId());

        } catch (Exception e) {
            job.setStatus("FAILED");
            job.setResult("Error: " + e.getMessage());
            jobRepository.save(job);
        }
    }
}